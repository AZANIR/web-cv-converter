# Required by nuxt-auth-utils (min ~32 random chars). If empty → "Empty password" in Docker logs.
NUXT_SESSION_PASSWORD=
NUXT_OAUTH_AUTH0_DOMAIN=
NUXT_OAUTH_AUTH0_CLIENT_ID=
NUXT_OAUTH_AUTH0_CLIENT_SECRET=
NUXT_OAUTH_AUTH0_AUDIENCE=
# Local Docker: http://localhost:8000 (compose sets NUXT_API_BASE_SERVER for SSR automatically)
# Production: https://yourdomain.com if API is on same host behind Caddy /api
NUXT_PUBLIC_API_URL=http://localhost:8000
