# Real tenant host only, e.g. dev-abc123.eu.auth0.com or myapp.us.auth0.com (NOT https://, NOT a placeholder)
AUTH0_DOMAIN=
AUTH0_API_AUDIENCE=https://cv-converter-api
# Same value as the SPA Auth0 Application Client ID (for X-Auth0-ID-Token email fallback).
AUTH0_CLIENT_ID=
SUPABASE_URL=https://xxxx.supabase.co
# Legacy JWT (eyJ...) or new secret key (sb_secret_...); the latter needs supabase-py 2.28+ (see requirements.txt).
SUPABASE_SERVICE_ROLE_KEY=
# AI: gemini (default) or anthropic
AI_PROVIDER=gemini
# Optional: provider fallback order (comma-separated), e.g. openrouter
# AI_FALLBACK_PROVIDERS=openrouter
# Google AI Studio / Gemini API key: https://aistudio.google.com/apikey
GEMINI_API_KEY=
# Optional: priority list of models (comma-separated); tried top-to-bottom
# GEMINI_MODELS=gemini-3-flash-preview,gemini-flash-latest,gemini-2.5-flash,gemini-2.0-flash
# Examples: gemini-2.5-flash, gemini-2.0-flash
GEMINI_MODEL=gemini-2.5-flash
# Optional: comma-separated fallback models (tried on 503 in order)
# GEMINI_FALLBACK_MODELS=gemini-2.0-flash,gemini-1.5-flash
# Optional: disable retry/fallback on 503
# GEMINI_RETRY_ON_503=true
# Optional: disable retry/fallback on 429 quota/rate limits
# GEMINI_RETRY_ON_429=true
# GEMINI_MAX_OUTPUT_TOKENS=65536
# GEMINI_ATTEMPT_TIMEOUT_SECONDS=45
# CONVERSION_AI_TIMEOUT_SECONDS=90
ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-haiku-4-5-20251001
# ANTHROPIC_MAX_TOKENS=4096
# Optional OpenRouter fallback
# OPENROUTER_API_KEY=
# OPENROUTER_MODEL=openai/gpt-4.1-mini
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# OPENROUTER_TIMEOUT_SECONDS=60
ALLOWED_ORIGINS=http://localhost:3000
# Optional: grant admin UI + /api/admin/* without setting profiles.role in Supabase (comma-separated).
# ADMIN_EMAILS=you@example.com,other@example.com
ADMIN_EMAILS=
# Optional overrides:
# MAX_UPLOAD_BYTES=5242880
# CONVERSIONS_PER_HOUR=10
# SIGNED_URL_EXPIRES_SECONDS=3600
